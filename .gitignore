# Dependencies
node_modules
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist


# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

# Go build artifacts / compiled binaries
*.exe
cs-api
apps/api/cs-api.exe

# Logs
*.log

# Kubernetes secrets — never commit real credentials (only *.example.yaml is tracked)
k8s/dev/secrets/*
!k8s/dev/secrets/*.example.yaml
!k8s/dev/secrets/README.md

# Helm real-secret overrides — only values.local.example.yaml is tracked
values.local.yaml

# Personal notes — local only, not for the repo
PROGRESS.md
docs/learning/

# Exported local CA certificate (machine-specific)
*.crt
